# Git LFS — large binary file types tracked by content hash, not path
*.gz filter=lfs diff=lfs merge=lfs -text
*.mtx filter=lfs diff=lfs merge=lfs -text
*.bam filter=lfs diff=lfs merge=lfs -text
*.bai filter=lfs diff=lfs merge=lfs -text
*.h5 filter=lfs diff=lfs merge=lfs -text
*.h5ad filter=lfs diff=lfs merge=lfs -text
*.bigwig filter=lfs diff=lfs merge=lfs -text
*.bw filter=lfs diff=lfs merge=lfs -text

# CellRanger / STARsolo output CSVs (can be large)
data/**/*.csv filter=lfs diff=lfs merge=lfs -text
